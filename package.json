{
  "name": "task-flow",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev:api": "pnpm --filter api start:dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm --parallel --stream --filter api --filter web run dev",
    "build": "pnpm -r run build",
    "lint": "pnpm -r run lint"
  }
}